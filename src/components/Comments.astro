---
interface Props {
  pageId:    string;
  pageTitle: string;
  pageUrl:   string;
}

const { pageId, pageTitle, pageUrl } = Astro.props;

// Ganti dengan App ID dari https://cusdis.com atau instance self-hosted kamu
const CUSDIS_APP_ID = 'ISI_APP_ID_CUSDIS_KAMU';
const CUSDIS_HOST  = 'https://cusdis.com';
---

<section class="mt-16 pt-8 border-t border-brand-border-light dark:border-brand-border-dark not-prose">
  <h2 class="font-lora text-xl font-semibold text-brand-text-light dark:text-brand-text-dark mb-6">
    Komentar
  </h2>

  {CUSDIS_APP_ID === 'ISI_APP_ID_CUSDIS_KAMU' ? (
    <div class="p-4 rounded-xl bg-brand-surface-light dark:bg-brand-surface-dark border border-brand-border-light dark:border-brand-border-dark text-sm text-brand-text-light/70 dark:text-brand-text-dark/70">
      <p>
        Untuk mengaktifkan komentar, daftarkan akun di{' '}
        <a href="https://cusdis.com" target="_blank" rel="noopener" class="text-brand-accent-light dark:text-brand-accent-dark hover:underline">cusdis.com</a>
        {' '}lalu isi <code class="text-xs bg-brand-bg-light dark:bg-brand-bg-dark px-1.5 py-0.5 rounded">CUSDIS_APP_ID</code> di file{' '}
        <code class="text-xs bg-brand-bg-light dark:bg-brand-bg-dark px-1.5 py-0.5 rounded">src/components/Comments.astro</code>.
      </p>
    </div>
  ) : (
    <div
      id="cusdis_thread"
      data-host={CUSDIS_HOST}
      data-app-id={CUSDIS_APP_ID}
      data-page-id={pageId}
      data-page-title={pageTitle}
      data-page-url={pageUrl}
    />
    <script async defer src={`${CUSDIS_HOST}/js/cusdis.es.js`} />
  )}
</section>
