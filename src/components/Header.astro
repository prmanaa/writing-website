---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/',        label: 'Beranda' },
  { href: '/tags',    label: 'Topik' },
  { href: '/search',  label: 'Cari' },
  { href: '/about',   label: 'Tentang' },
];
---

<header class="sticky top-0 z-50 bg-brand-bg-light/90 dark:bg-brand-bg-dark/90 backdrop-blur-sm border-b border-brand-border-light dark:border-brand-border-dark">
  <div class="max-w-5xl mx-auto px-5 sm:px-8 h-14 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="font-lora font-semibold text-lg text-brand-text-light dark:text-brand-text-dark hover:text-brand-accent-light dark:hover:text-brand-accent-dark transition-colors shrink-0">
      Wildan
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-6" aria-label="Navigasi utama">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'nav-link text-sm',
            currentPath === link.href && 'text-brand-accent-light dark:text-brand-accent-dark font-medium'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-1">
      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Ganti tema"
        class="btn-icon"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        aria-label="Buka menu"
        aria-expanded="false"
        class="btn-icon sm:hidden"
      >
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="hidden sm:hidden border-t border-brand-border-light dark:border-brand-border-dark">
    <nav class="max-w-5xl mx-auto px-5 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2 rounded-lg text-sm nav-link',
            currentPath === link.href && 'bg-brand-surface-light dark:bg-brand-surface-dark text-brand-accent-light dark:text-brand-accent-dark font-medium'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Dark mode toggle
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    iconMenu?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
